{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HealthChecks": {
    "DiskSpace": {
      "DriveName": "C",
      "MinimumFreeMegabytes": 1024
    },
    "HttpBin": {
      "Healthy": {
        "Url": "https://httpbin.org/status/200",
        "TimeoutSeconds": 3
      },
      "ServerError": {
        "Url": "https://httpbin.org/status/500",
        "TimeoutSeconds": 3
      },
      "Timeout": {
        "Url": "https://httpbin.org/delay/5",
        "TimeoutSeconds": 3
      }
    },
    "PostgreSql": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "ConnectionString": "_secret_"
    },
    "Redis": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "ConnectionString": "_secret_"
    },
    "RabbitMq": {
      "Enabled": true,
      "TimeoutSeconds": 5,
      "ManagementUrl": "http://localhost:15672",
      "ConnectionString": "_secret_"
    },
    "Keycloak": {
      "Enabled": true,
      "TimeoutSeconds": 10,
      "HealthPath": "/health/ready",
      "BaseUrl": "http://localhost:9000"
    }
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "HealthCheck Examples",
        "Uri": "http://localhost:5264/health"
      }
    ],
    "EvaluationTimeInSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 60
  }
}
