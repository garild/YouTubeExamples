{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HealthChecks": {
    "DiskSpace": {
      "DriveName": "C",
      "MinimumFreeMegabytes": 1024
    },
    "HttpBin": {
      "Healthy": {
        "Url": "https://httpbin.org/status/200",
        "TimeoutSeconds": 3
      },
      "ServerError": {
        "Url": "https://httpbin.org/status/500",
        "TimeoutSeconds": 3
      },
      "Timeout": {
        "Url": "https://httpbin.org/delay/5",
        "TimeoutSeconds": 3
      }
    }
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "HealthCheck Examples",
        "Uri": "http://localhost:5264/health"
      }
    ],
    "EvaluationTimeInSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 60
  }
}
